# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# .env is listed in .gitignore — it will never be committed.

# ── Site ──────────────────────────────────────────────────────────────────────
BASE_URL=https://qauto.forstudy.space

# ── HTTP Basic Auth (required to access the staging site) ────────────────────
HTTP_USERNAME=guest
HTTP_PASSWORD=welcome2qauto

# ── Test user (created once by auth.setup.js, reused across all test runs) ───
USER_EMAIL=aqa-testuser@test.com
USER_PASSWORD=Password1
